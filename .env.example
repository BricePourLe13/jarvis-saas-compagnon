# ========================================
# JARVIS SAAS - ENVIRONMENT VARIABLES
# ========================================
# Ce fichier liste TOUTES les variables d''environnement nécessaires.
# Copier ce fichier en `.env.local` et remplir avec les vraies valeurs.

# ========================================
# 1. NEXT.JS CONFIGURATION
# ========================================
NEXT_PUBLIC_APP_URL=http://localhost:3001
PORT=3001

# ========================================
# 2. SUPABASE (Base de données + Auth)
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ========================================
# 3. OPENAI (Realtime Voice API)
# ========================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# 4. RESEND (Email)
# ========================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=no-reply@jarvis-group.net

# ========================================
# 5. SENTRY (Monitoring)
# ========================================
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oxxxxx.ingest.sentry.io/xxxxx
SENTRY_ENVIRONMENT=development
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=jarvis-group
SENTRY_PROJECT=jarvis-saas-compagnon

# ========================================
# 6. UPSTASH QSTASH (Cron Jobs)
# ========================================
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QSTASH_CURRENT_SIGNING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QSTASH_NEXT_SIGNING_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# 7. HCAPTCHA (Anti-bot)
# ========================================
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here
HCAPTCHA_SECRET_KEY=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ========================================
# 8. RATE LIMITING
# ========================================
RATE_LIMIT_MAX=100
RATE_LIMIT_VOICE_MAX=30

# ========================================
# 9. FEATURES FLAGS (Optionnel)
# ========================================
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_VERBOSE_LOGS=false
NEXT_PUBLIC_SENTRY_ENABLED=false
